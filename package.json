{
  "name": "crypto-testing-app",
  "version": "1.0.0",
  "type": "module",
  "author": "Valentyn Savkun",
  "license": "MIT",
  "description": "Тестування алгоритму Ed448 для КПІ/ВНТУ",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0"
  },
  "jest": {
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageReporters": [
      "text",
      "html"
    ]
  }
}